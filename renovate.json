{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "groupName": "Spring dependencies",
      "matchPackageNames": [
        "org.springframework.boot{/,}**",
        "org.springframework.cloud{/,}**",
        "org.springframework.ai{/,}**"
      ]
    }
  ]
}
