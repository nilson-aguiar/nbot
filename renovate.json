{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchPackagePrefixes": [
        "org.springframework.boot",
        "org.springframework.cloud",
        "org.springframework.ai"
      ],
      "groupName": "Spring dependencies"
    }
  ]
}
